// ============================================================
//  CAMERA INIT
//  The OV2640 on AI-Thinker / HW-381 boards cannot have its
//  frame-size changed via set_framesize() while the DMA/I2S
//  capture engine is running - doing so causes FB-OVF errors.
//  The ONLY safe approach is full deinit ? reinit with the new
//  config.  initCameraMode() encapsulates that.
// ============================================================

// Build camera_config_t for a given mode
static camera_config_t buildCamConfig(framesize_t fs, int quality, int fbCount) {
  camera_config_t cfg;
  cfg.ledc_channel = LEDC_CHANNEL_0;
  cfg.ledc_timer   = LEDC_TIMER_0;
  cfg.pin_d0  = Y2_GPIO_NUM; cfg.pin_d1  = Y3_GPIO_NUM;
  cfg.pin_d2  = Y4_GPIO_NUM; cfg.pin_d3  = Y5_GPIO_NUM;
  cfg.pin_d4  = Y6_GPIO_NUM; cfg.pin_d5  = Y7_GPIO_NUM;
  cfg.pin_d6  = Y8_GPIO_NUM; cfg.pin_d7  = Y9_GPIO_NUM;
  cfg.pin_xclk     = XCLK_GPIO_NUM;
  cfg.pin_pclk     = PCLK_GPIO_NUM;
  cfg.pin_vsync    = VSYNC_GPIO_NUM;
  cfg.pin_href     = HREF_GPIO_NUM;
  cfg.pin_sccb_sda = SIOD_GPIO_NUM;
  cfg.pin_sccb_scl = SIOC_GPIO_NUM;
  cfg.pin_pwdn     = PWDN_GPIO_NUM;
  cfg.pin_reset    = RESET_GPIO_NUM;
  cfg.xclk_freq_hz = 20000000;
  cfg.pixel_format = PIXFORMAT_JPEG;
  cfg.frame_size   = fs;
  cfg.jpeg_quality = quality;
  cfg.fb_count     = fbCount;
  if (psramFound()) {
    cfg.fb_location = CAMERA_FB_IN_PSRAM;
    // LATEST mode: newest frame always available, older ones auto-discarded
    // - prevents FB-OVF during streaming
    cfg.grab_mode = (fbCount > 1) ? CAMERA_GRAB_LATEST : CAMERA_GRAB_WHEN_EMPTY;
  } else {
    cfg.fb_location = CAMERA_FB_IN_DRAM;
    cfg.grab_mode   = CAMERA_GRAB_WHEN_EMPTY;
  }
  return cfg;
}

// Full deinit + reinit - the only safe way to change resolution
bool initCameraMode(framesize_t fs, int quality, int fbCount) {
  esp_camera_deinit();
  delay(100);   // let DMA/I2S engine fully stop
  camera_config_t cfg = buildCamConfig(fs, quality, fbCount);
  esp_err_t err = esp_camera_init(&cfg);
  if (err != ESP_OK) {
    Serial.printf("[CAM] Reinit FAILED 0x%x\n", err);
    return false;
  }
  Serial.printf("[CAM] Mode: fs=%d q=%d fb=%d\n", (int)fs, quality, fbCount);
  return true;
}

// First-time init on boot (stream mode: VGA, 2 buffers for GRAB_LATEST)
bool initCamera() {
  framesize_t fs = psramFound() ? (framesize_t)streamFrameSize : FRAMESIZE_VGA;
  int quality    = psramFound() ? 10 : 12;
  int fbCount    = psramFound() ? 2  : 1;
  camera_config_t cfg = buildCamConfig(fs, quality, fbCount);
  esp_err_t err = esp_camera_init(&cfg);
  if (err != ESP_OK) { Serial.printf("📷 FAILED 0x%x\n", err); return false; }
  Serial.printf("[CAM] Boot: VGA MJPEG PSRAM=%d\n", (int)psramFound());
  return true;
}


// ============================================================
//  CAMERA SETTINGS HELPERS
// ============================================================

bool initSD() {
  if (!SD_MMC.begin("/sdcard", true)) { Serial.println("💾 Failed"); return false; }
  if (SD_MMC.cardType() == CARD_NONE) { Serial.println("💾 No card"); return false; }
  Serial.printf("[SD] Ready %.1f GB\n",
    (float)SD_MMC.totalBytes() / (1024.0*1024*1024));
  return true;
}

// ============================================================
//  HELPERS
// ============================================================
String getTimestamp() {
  struct tm ti;
  if (!getLocalTime(&ti)) {
    char buf[20]; snprintf(buf, sizeof(buf), "notime_%lu", millis()/1000);
    return String(buf);
  }
  char buf[22]; strftime(buf, sizeof(buf), "%Y-%m-%d_%H-%M-%S", &ti);
  return String(buf);
}

String getResLabel(int fs) {
  switch(fs) {
    case 1:  return "QQVGA";
    case 5:  return "QVGA";
    case 8:  return "VGA";
    case 9:  return "SVGA";
    case 10: return "XGA";
    case 11: return "HD";
    case 12: return "SXGA";
    case 13: return "UXGA";
    default: return "VGA";
  }
}

String getUptime() {
  unsigned long elapsed = (millis() - bootMs) / 1000;
  unsigned long h = elapsed / 3600;
  unsigned long m = (elapsed % 3600) / 60;
  char buf[16];
  snprintf(buf, sizeof(buf), "%luh %lum", h, m);
  return String(buf);
}

void applyStreamResolution() {
  int fbCount = psramFound() ? 2 : 1;
  initCameraMode((framesize_t)streamFrameSize, STREAM_JPEG_QUALITY, fbCount);
  Serial.printf("[CAM] Stream mode: res=%d(%s) fps=%d\n",
    streamFrameSize, getResLabel(streamFrameSize).c_str(), streamFps);
}

// Delete all files in /photos and /videos
void deleteAllSD() {
  if(sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  auto rmDir = [](const char* dir) -> int {
    int count = 0;
    File root = SD_MMC.open(dir);
    if (!root || !root.isDirectory()) return 0;
    File f = root.openNextFile();
    while (f) {
      if (!f.isDirectory()) {
        String path = String(dir) + "/" + String(f.name());
        f.close();
        SD_MMC.remove(path.c_str());
        count++;
        f = root.openNextFile();
      } else {
        f.close();  // explicitly close directory handles before moving to next entry
        f = root.openNextFile();
      }
    }
    root.close();
    return count;
  };
  int n = rmDir("/photos") + rmDir("/videos");
  if(sdMutex) xSemaphoreGive(sdMutex);
  photoCount = 0; videoCount = 0;
  Serial.printf("[SD] Deleted all: %d files\n", n);
}

int countPhotos() {
  int c=0; File r=SD_MMC.open("/photos");
  if (r&&r.isDirectory()){File f=r.openNextFile();while(f){if(!f.isDirectory())c++;f=r.openNextFile();}}
  if(r) r.close();
  return c;
}
int countVideos() {
  int c=0; File r=SD_MMC.open("/videos");
  if (r&&r.isDirectory()){File f=r.openNextFile();while(f){if(!f.isDirectory())c++;f=r.openNextFile();}}
  if(r) r.close();
  return c;
}

// ============================================================
//  ARM / DISARM  - resets warm-up and consecutive counters
// ============================================================
void armMotion() {
  motionArmed       = true;
  prevFrameReady    = false;   // force fresh baseline on first frame
  mdWarmupCount     = 0;
  mdWarmedUp        = false;
  mdConsecutive     = 0;
  Serial.println("[MD] ARMED - warm-up started");
}

void disarmMotion() {
  motionArmed    = false;
  mdWarmedUp     = false;
  mdConsecutive  = 0;
  Serial.println("[MD] DISARMED");
}

