  const char* rl[] = {
    "96x96","QQVGA","QCIF","HQVGA","240x240","QVGA 320x240","CIF 400x296",
    "HVGA 480x320","VGA 640x480","SVGA 800x600","XGA 1024x768",
    "HD 1280x720","SXGA 1280x1024","UXGA 1600x1200"
  };
  String resLabel = (streamFrameSize>=0&&streamFrameSize<=13) ? rl[streamFrameSize] : "VGA 640x480";
  StaticJsonDocument<640> doc;
  doc["uptime"]       = getUptime();
  doc["wifi"]         = (WiFi.status()==WL_CONNECTED);
  doc["ip"]           = WiFi.localIP().toString();
  doc["rssi"]         = WiFi.RSSI();
  doc["temp"]         = String(temp,1);
  doc["resolution"]   = resLabel + " @" + String(streamFps) + "fps";
  doc["streamRes"]    = streamFrameSize;
  doc["streamFps"]    = streamFps;
  doc["photos"]       = photoCount;
  doc["videos"]       = videoCount;
  doc["armed"]        = motionArmed;
  doc["warmedUp"]     = mdWarmedUp;
  doc["sensitivity"]  = motionSensitivity;
  doc["cooldown"]     = motionCooldownS;
  doc["recording"]    = aviRecording;
  doc["telegram"]     = telegramEnabled;
  doc["timelapse"]    = timelapseActive;
  doc["tlInterval"]   = timelapseIntervalS;
  doc["emailEnabled"] = emailEnabled;
  doc["freeHeap"]     = (uint32_t)(ESP.getFreeHeap()/1024);
  doc["freePsram"]    = (uint32_t)(ESP.getFreePsram()/1024);
  String out; serializeJson(doc,out);
  webServer.send(200,"application/json",out);
}

// ============================================================
//  /api/sdstats -- SD FAT queries on user demand only
// ============================================================
void apiSdStats() {
  uint64_t tot=SD_MMC.totalBytes(), used=SD_MMC.usedBytes();
  String t="Unknown";
  switch(SD_MMC.cardType()){
    case CARD_MMC:  t="MMC";        break;
    case CARD_SD:   t="SDSC";       break;
    case CARD_SDHC: t="SDHC/SDXC"; break;
    default: break;
  }
  StaticJsonDocument<192> doc;
  doc["sdType"]  = t;
  doc["sdTotal"] = (uint32_t)(tot/1048576);
  doc["sdUsed"]  = (uint32_t)(used/1048576);
  doc["sdFree"]  = (uint32_t)((tot-used)/1048576);
  String out; serializeJson(doc,out);
  webServer.send(200,"application/json",out);
}


// NEW: dedicated motion arm/disarm endpoint
void apiMotion() {
  if (webServer.hasArg("armed")) {
    int v = webServer.arg("armed").toInt();
    if (v) armMotion(); else disarmMotion();
  }
  webServer.send(200,"application/json",
    String("{\"armed\":")+( motionArmed?"true":"false")+"}");
}

// GET /api/timelapse?active=1&interval=30
void apiTimelapse() {
  if (webServer.hasArg("active")) {
    timelapseActive = webServer.arg("active").toInt() != 0;
    if (timelapseActive) lastTimelapseMs = 0; // fire first capture immediately
    Serial.printf("[TL] Timelapse %s\n", timelapseActive ? "STARTED" : "STOPPED");
  }
  if (webServer.hasArg("interval")) {
    timelapseIntervalS = constrain(webServer.arg("interval").toInt(), 1, 3600);
    Serial.printf("[TL] Interval set to %ds\n", timelapseIntervalS);
  }
  // Persist across reboot
  preferences.begin("surveil", false);
  preferences.putBool("tlActive",   timelapseActive);
  preferences.putInt ("tlInterval", timelapseIntervalS);
  preferences.end();
  webServer.send(200,"application/json",
    String("{\"active\":") + (timelapseActive?"true":"false") +
    ",\"interval\":" + String(timelapseIntervalS) + "}");
}

// Photo handler: schedule work in loop() and return immediately.
// captureAndSavePhoto() takes ~2s - we must not block handleClient().
void apiPhoto() {
  if (pendingJob.type != JOB_NONE) {
    webServer.send(503,"application/json","{\"ok\":false,\"error\":\"Busy\"}"); return;
  }
  pendingJob.flash = webServer.hasArg("flash") && webServer.arg("flash") == "1";
  pendingJob.type  = JOB_PHOTO;
  webServer.send(200,"application/json","{\"ok\":true,\"queued\":true}");
}

void apiStreamStart() {
  // Accept optional res/fps overrides from the start request
  if (webServer.hasArg("res")) {
    int r = webServer.arg("res").toInt();
    if (r >= 0 && r <= 13) { streamFrameSize = r; }
  }
  if (webServer.hasArg("fps")) {
    int f = webServer.arg("fps").toInt();
    if (f >= 1 && f <= 30) { streamFps = f; }
  }
  // Stop stream while we reinit camera (safe - nothing streaming yet)
  streamActive = false;
  delay(100);
  applyStreamResolution();
  delay(150);
  streamActive = true;
  webServer.send(200,"application/json","{\"ok\":true}");
}
void apiStreamStop() {
  streamActive = false;
  delay(150);   // let stream handler exit its loop
  webServer.send(200,"application/json","{\"ok\":true}");
}

void apiStreamQuality() {
  bool wasStreaming = streamActive;
  // Stop stream before changing resolution
  if (wasStreaming) {
    streamActive = false;
    delay(200);   // let httpd task finish current frame
  }
  if (webServer.hasArg("res")) {
    int r = webServer.arg("res").toInt();
    if (r >= 0 && r <= 13) { streamFrameSize = r; }
  }
  if (webServer.hasArg("fps")) {
    int f = webServer.arg("fps").toInt();
    if (f >= 1 && f <= 30) { streamFps = f; }
  }
  // Reinit camera at new resolution
  applyStreamResolution();
  delay(100);
  if (wasStreaming) { streamActive = true; }
  webServer.send(200,"application/json","{\"ok\":true}");
}

void apiRestart() {
  webServer.send(200,"application/json","{\"ok\":true}");
  delay(300);
  ESP.restart();
}

// Record handler: schedule work in loop() and return immediately.
// Recording takes 5-120s - blocking handleClient() would freeze dashboard.
void apiRecord(){
  int secs=webServer.hasArg("secs")?webServer.arg("secs").toInt():10;
  secs=constrain(secs,5,120);
  if(aviRecording||pendingJob.type!=JOB_NONE){
    webServer.send(200,"application/json","{\"ok\":false,\"error\":\"Busy\"}"); return;
  }
  pendingJob.recSecs = secs;
  pendingJob.type    = JOB_RECORD;
  webServer.send(200,"application/json","{\"ok\":true,\"queued\":true,\"secs\":"+String(secs)+"}");
}

// OPT: Cached file list - rebuilt only when photoCount or videoCount changes.
// The SD directory scan + sort is O(n log n) flash I/O; for typical use the
// file list is stable between captures so we serve the cached result.
struct FileEntry { char name[64]; char path[96]; size_t size; };
static std::vector<FileEntry> eventsCache;

static void rebuildEventsCache() {
  eventsCache.clear();
  eventsCache.reserve(64);
  auto scanDir = [](const char* dir) {
    File root = SD_MMC.open(dir);
    if (!root || !root.isDirectory()) return;
    File f = root.openNextFile();
    while (f) {
      if (!f.isDirectory()) {
        FileEntry e;
        strlcpy(e.name, f.name(),    sizeof(e.name));
        snprintf(e.path, sizeof(e.path), "%s/%s", dir, f.name());
        e.size = f.size();
        eventsCache.push_back(e);
      }
      f = root.openNextFile();
    }
    root.close();
  };
  scanDir("/photos");
  scanDir("/videos");
  std::sort(eventsCache.begin(), eventsCache.end(),
    [](const FileEntry& a, const FileEntry& b){ return strcmp(a.name, b.name) > 0; });
  eventsCachePhotoSnap = photoCount;
  eventsCacheVideoSnap = videoCount;
  eventsCacheDirty     = false;
}

void apiEvents(){
  int offset = webServer.hasArg("offset") ? webServer.arg("offset").toInt() : 0;
  int limit  = webServer.hasArg("limit")  ? webServer.arg("limit").toInt()  : EVENTS_PAGE_SIZE;
  limit = constrain(limit, 1, 100);

  // OPT: Only rescan SD when the file list has changed (dirty flag or count mismatch).
  if (eventsCacheDirty ||
      photoCount != eventsCachePhotoSnap ||
      videoCount != eventsCacheVideoSnap) {
    rebuildEventsCache();
  }

  int total = (int)eventsCache.size();
  DynamicJsonDocument doc(8192);
  doc["total"] = total;
  JsonArray arr = doc.createNestedArray("files");

  int end = min(offset + limit, total);
  for (int i = offset; i < end; i++) {
    JsonObject o = arr.createNestedObject();
    o["name"] = eventsCache[i].name;
    o["path"] = eventsCache[i].path;
    o["size"] = String(eventsCache[i].size / 1024) + " KB";
  }
  String out; serializeJson(doc, out);
  webServer.send(200, "application/json", out);
}

void apiDeleteAll() {
  int before = photoCount + videoCount;  // capture before deleteAllSD() resets counters
  deleteAllSD();
  eventsCacheDirty = true;  // OPT: force events cache rebuild after mass delete
  webServer.send(200, "application/json",
    "{\"ok\":true,\"count\":" + String(before) + "}");
}

void apiDownload(){
  if(!webServer.hasArg("f")){webServer.send(400,"text/plain","Missing f");return;}
  String path=webServer.arg("f");
  if(!path.startsWith("/photos/")&&!path.startsWith("/videos/")){webServer.send(403,"text/plain","Forbidden");return;}
  File f=SD_MMC.open(path.c_str(),FILE_READ);
  if(!f){webServer.send(404,"text/plain","Not found");return;}
  bool jpg=path.endsWith(".jpg")||path.endsWith(".jpeg");
  webServer.sendHeader("Content-Disposition","attachment; filename=\""+path.substring(path.lastIndexOf('/')+1)+"\"");
  webServer.streamFile(f,jpg?"image/jpeg":"video/x-msvideo"); f.close();
}
void apiThumb(){
  if(!webServer.hasArg("f")){webServer.send(404,"text/plain","No f");return;}
  String path=webServer.arg("f");
  if(!path.startsWith("/photos/")){webServer.send(403,"text/plain","Forbidden");return;}
  File f=SD_MMC.open(path.c_str(),FILE_READ);
  if(!f){webServer.send(404,"text/plain","Not found");return;}
  webServer.streamFile(f,"image/jpeg"); f.close();
}
void apiDelete(){
  if(!webServer.hasArg("f")){webServer.send(400,"application/json","{\"ok\":false}");return;}
  String path=webServer.arg("f");
  if(!path.startsWith("/photos/")&&!path.startsWith("/videos/")){webServer.send(403,"application/json","{\"ok\":false}");return;}
  bool ok=SD_MMC.remove(path.c_str());
  if(ok){
    if(path.startsWith("/photos/")) photoCount = max(0, photoCount - 1);
    else                            videoCount = max(0, videoCount - 1);
  }
  webServer.send(200,"application/json",ok?"{\"ok\":true}":"{\"ok\":false,\"error\":\"Delete failed\"}");
}
void apiConfig(){
  if(webServer.method()==HTTP_POST){
    StaticJsonDocument<768> doc;
    if(deserializeJson(doc,webServer.arg("plain"))){
      webServer.send(400,"application/json","{\"ok\":false}"); return;
    }
    bool needReboot = false;
    // Update in-RAM values immediately (these are used by the running system)
    if(doc.containsKey("sensitivity")){
      motionSensitivity=(int)doc["sensitivity"];
      mdThreshold=sliderToThreshold(motionSensitivity);
    }
    if(doc.containsKey("cooldown")){
      motionCooldownS=(int)doc["cooldown"];
    }
    if(doc.containsKey("wifiSSID")) needReboot=true;
    if(doc.containsKey("wifiPass")) needReboot=true;
    if(doc.containsKey("botToken")) needReboot=true;
    if(doc.containsKey("chatID"))   needReboot=true;
    // OPT: Send HTTP response BEFORE NVS flash writes.
    // Client gets its 200 OK instantly; NVS erase/write (~5-15ms per key)
    // happens after the TCP stack has queued the response bytes.
    // OPT: Single preferences.begin()/end() for all keys (was one open/close per key).
    webServer.send(200,"application/json",
      needReboot ? "{\"ok\":true,\"reboot\":true}" : "{\"ok\":true,\"reboot\":false}");
    preferences.begin("surveil", false);
    if(doc.containsKey("sensitivity")) preferences.putInt("motionSens", motionSensitivity);
    if(doc.containsKey("cooldown"))    preferences.putInt("motionCool", motionCooldownS);
    if(doc.containsKey("wifiSSID"))    preferences.putString("wifiSSID", doc["wifiSSID"].as<String>());
    if(doc.containsKey("wifiPass"))    preferences.putString("wifiPass", doc["wifiPass"].as<String>());
    if(doc.containsKey("botToken"))    preferences.putString("botToken", doc["botToken"].as<String>());
    if(doc.containsKey("chatID"))      preferences.putString("chatID",   doc["chatID"].as<String>());
    preferences.end();
    if(needReboot){ delay(800); ESP.restart(); }
  } else {
    StaticJsonDocument<512> doc;
    doc["sensitivity"]  = motionSensitivity;
    doc["cooldown"]     = motionCooldownS;
    preferences.begin("surveil", true);
    doc["wifiSSID"]     = preferences.getString("wifiSSID","");
    doc["tgConfigured"] = (preferences.getString("botToken","").length() > 0);
    preferences.end();
    doc["apMode"]       = apMode;
    String out; serializeJson(doc,out);
    webServer.send(200,"application/json",out);
  }
}


// ============================================================
//  CAMERA CONTROL - exact CameraWebServer approach
//  GET /control?var=brightness&val=2
//  One request per variable, direct sensor register write.
//  No JSON, no mutex, no stream stop. Works exactly like the
//  official Espressif CameraWebServer example.
// ============================================================
void apiCamControl() {
  if (!webServer.hasArg("var") || !webServer.hasArg("val")) {
    webServer.send(400, "text/plain", "Missing var or val"); return;
  }
  String var = webServer.arg("var");
  int    val = webServer.arg("val").toInt();
  sensor_t* s = esp_camera_sensor_get();
  if (!s) { webServer.send(500, "text/plain", "No sensor"); return; }

  int res = 0;
  if      (var == "framesize")     { if (s->pixformat == PIXFORMAT_JPEG) res = s->set_framesize(s, (framesize_t)val); }
  else if (var == "quality")       res = s->set_quality(s, val);
  else if (var == "contrast")      res = s->set_contrast(s, val);
  else if (var == "brightness")    res = s->set_brightness(s, val);
  else if (var == "saturation")    res = s->set_saturation(s, val);
  else if (var == "gainceiling")   res = s->set_gainceiling(s, (gainceiling_t)val);
  else if (var == "colorbar")      res = s->set_colorbar(s, val);
  else if (var == "awb")           res = s->set_whitebal(s, val);
  else if (var == "agc")           res = s->set_gain_ctrl(s, val);
  else if (var == "aec")           res = s->set_exposure_ctrl(s, val);
  else if (var == "hmirror")       res = s->set_hmirror(s, val);
  else if (var == "vflip")         res = s->set_vflip(s, val);
  else if (var == "awb_gain")      res = s->set_awb_gain(s, val);
  else if (var == "agc_gain")      res = s->set_agc_gain(s, val);
  else if (var == "aec_value")     res = s->set_aec_value(s, val);
  else if (var == "aec2")          res = s->set_aec2(s, val);
  else if (var == "dcw")           res = s->set_dcw(s, val);
  else if (var == "bpc")           res = s->set_bpc(s, val);
  else if (var == "wpc")           res = s->set_wpc(s, val);
  else if (var == "raw_gma")       res = s->set_raw_gma(s, val);
  else if (var == "lenc")          res = s->set_lenc(s, val);
  else if (var == "special_effect")res = s->set_special_effect(s, val);
  else if (var == "wb_mode")       res = s->set_wb_mode(s, val);
  else if (var == "ae_level")      res = s->set_ae_level(s, val);
  else if (var == "sharpness")     res = s->set_sharpness(s, val);
  else if (var == "led_intensity") {
    // LED intensity via LEDC PWM - same as CameraWebServer enable_led().
    // ledcWrite(pin, 0) fully cuts PWM output; no digitalWrite needed.
    ledDuty = constrain(val, 0, 255);
    ledcWrite(FLASH_LED_PIN, ledDuty);
    Serial.printf("[CAM] control: led_intensity = %d\n", ledDuty);
    webServer.send(200, "text/plain", "OK"); return;
  }
  else { webServer.send(404, "text/plain", "Unknown var"); return; }

  Serial.printf("[CAM] control: %s = %d (res=%d)\n", var.c_str(), val, res);
  if (res < 0) { webServer.send(500, "text/plain", "Sensor error"); return; }
  webServer.send(200, "text/plain", "OK");
}

// GET /xclk?xclk=20 - set XCLK frequency in MHz, same as CameraWebServer
void apiXclk() {
  if (!webServer.hasArg("xclk")) { webServer.send(400, "text/plain", "Missing xclk"); return; }
  int xclk = webServer.arg("xclk").toInt();
  xclk = constrain(xclk, 2, 40);
  sensor_t* s = esp_camera_sensor_get();
  if (!s) { webServer.send(500, "text/plain", "No sensor"); return; }
  int res = s->set_xclk(s, LEDC_TIMER_0, xclk);
  Serial.printf("[CAM] XCLK set to %d MHz (res=%d)\n", xclk, res);
  if (res != 0) { webServer.send(500, "text/plain", "XCLK error"); return; }
  webServer.send(200, "text/plain", "OK");
}

// GET /camstatus - reads actual sensor register values, same as CameraWebServer /status
// Dashboard calls this on load to populate all sliders with real current values.
void apiCamStatus() {
  sensor_t* s = esp_camera_sensor_get();
  if (!s) { webServer.send(500, "application/json", "{}"); return; }
  StaticJsonDocument<768> doc;
  doc["framesize"]      = s->status.framesize;
  doc["quality"]        = s->status.quality;
  doc["brightness"]     = s->status.brightness;
  doc["contrast"]       = s->status.contrast;
  doc["saturation"]     = s->status.saturation;
  doc["sharpness"]      = s->status.sharpness;
  doc["special_effect"] = s->status.special_effect;
  doc["wb_mode"]        = s->status.wb_mode;
  doc["awb"]            = s->status.awb;
  doc["awb_gain"]       = s->status.awb_gain;
  doc["aec"]            = s->status.aec;
  doc["aec2"]           = s->status.aec2;
  doc["ae_level"]       = s->status.ae_level;
  doc["aec_value"]      = s->status.aec_value;
  doc["agc"]            = s->status.agc;
  doc["agc_gain"]       = s->status.agc_gain;
  doc["gainceiling"]    = s->status.gainceiling;
  doc["bpc"]            = s->status.bpc;
  doc["wpc"]            = s->status.wpc;
  doc["raw_gma"]        = s->status.raw_gma;
  doc["lenc"]           = s->status.lenc;
  doc["hmirror"]        = s->status.hmirror;
  doc["vflip"]          = s->status.vflip;
  doc["dcw"]            = s->status.dcw;
  doc["colorbar"]       = s->status.colorbar;
  doc["xclk"]           = s->xclk_freq_hz / 1000000;  // MHz, matches CameraWebServer /status
  doc["led_intensity"]  = ledDuty;  // actual current PWM duty
  String out; serializeJson(doc, out);
  webServer.send(200, "application/json", out);
}

void initWebServer(){
  // Serve gzip-compressed dashboard (73% smaller than plain HTML)
  webServer.on("/",[](){ 
    webServer.sendHeader("Cache-Control","no-cache");
    webServer.sendHeader("Content-Encoding","gzip");
    webServer.send_P(200,"text/html",(const char*)DASHBOARD_HTML_GZ, DASHBOARD_HTML_GZ_LEN);
  });
  webServer.on("/api/status",          HTTP_GET,    apiStatus);
  webServer.on("/api/sdstats",         HTTP_GET,    apiSdStats);
  webServer.on("/api/photo",           HTTP_GET,    apiPhoto);
  webServer.on("/api/stream/start",    HTTP_GET,    apiStreamStart);
  webServer.on("/api/stream/stop",     HTTP_GET,    apiStreamStop);
  webServer.on("/api/stream/quality",  HTTP_GET,    apiStreamQuality);
  webServer.on("/api/motion",          HTTP_GET,    apiMotion);
  webServer.on("/api/timelapse",        HTTP_GET,    apiTimelapse);
  webServer.on("/api/record",          HTTP_GET,    apiRecord);
  webServer.on("/api/events",          HTTP_GET,    apiEvents);
  webServer.on("/api/download",        HTTP_GET,    apiDownload);
  webServer.on("/api/thumb",           HTTP_GET,    apiThumb);
  webServer.on("/api/delete",          HTTP_DELETE, apiDelete);
  webServer.on("/api/deleteall",       HTTP_DELETE, apiDeleteAll);
  webServer.on("/api/config",          HTTP_GET,    apiConfig);
  webServer.on("/api/config",          HTTP_POST,   apiConfig);
  webServer.on("/control",              HTTP_GET,    apiCamControl);  // CameraWebServer-compatible
  webServer.on("/camstatus",            HTTP_GET,    apiCamStatus);
  webServer.on("/xclk",                 HTTP_GET,    apiXclk);
  webServer.on("/api/restart",         HTTP_GET,    apiRestart);
  webServer.begin();
  Serial.println("[WEB] :80 ready");
}

// ============================================================
//  TELEGRAM COMMAND PROCESSOR
// ============================================================
void runTelegramRecord(int secs){
  tgSend("🎥 Starting "+String(secs)+"s "+getResLabel(streamFrameSize)+" recording...");
  if(!startAVIRecording(secs)){tgSend("? Could not start recording");return;}
  unsigned long dl=millis()+(unsigned long)(secs*1000);
  const unsigned long frameIntervalMs = 100;  // 10 fps - keeps file size manageable for Telegram upload
  while(millis()<dl){
    unsigned long frameStart = millis();
    camera_fb_t* fb=esp_camera_fb_get();
    if(fb){addAVIFrame(fb);esp_camera_fb_return(fb);}
    webServer.handleClient();
    unsigned long elapsed = millis() - frameStart;
    if (elapsed < frameIntervalMs) delay(frameIntervalMs - elapsed);
  }
  String path=finishAVIRecording();
  File vf=SD_MMC.open(path.c_str(),FILE_READ); uint32_t fsz=vf?vf.size():0; if(vf)vf.close();
  tgEnqueueVideo(path,
    "🎬 AVI Video recorded!\n"
    "📊 Stats:\n"
    "🎞 Frames: "+String(aviFrameCount)+"\n"
    "🎥 Resolution: "+String(aviWidth)+"x"+String(aviHeight)+"\n"
    "📁 Size: "+String(fsz/1024)+" KB\n"
    "⏱ Duration: "+String(secs)+"s\n"
    "💾 Saved to SD");
}


// ============================================================
//  SETUP
// ============================================================
// ============================================================
//  PENDING JOB EXECUTOR  (called from loop every iteration)
// ============================================================
void executePendingJob() {
  if (pendingJob.type == JOB_NONE) return;

  if (pendingJob.type == JOB_PHOTO) {
    pendingJob.type = JOB_NONE;  // clear before work so re-entrant calls see idle
    bool flash = pendingJob.flash;
    bool ok = captureAndSavePhoto(true, "Dashboard Button", flash);
    // Result is already sent via Telegram; /api/status reflects updated photoCount
    Serial.printf("[JOB] Photo done, ok=%d\n", (int)ok);
  }
  else if (pendingJob.type == JOB_RECORD) {
    int secs = pendingJob.recSecs;
    pendingJob.type = JOB_NONE;  // clear so motion/photo can run after record
    tgEnqueue("🎥 Starting "+String(secs)+"s "+getResLabel(streamFrameSize)+" recording...");
    if (!startAVIRecording(secs)) {
      tgEnqueue("Could not open file for recording");
      return;
    }
    unsigned long dl = millis() + (unsigned long)(secs * 1000);
    const unsigned long frameIntervalMs = 100;  // 10 fps - keeps file size manageable for Telegram upload
    while (millis() < dl) {
      unsigned long frameStart = millis();
      camera_fb_t* fb = esp_camera_fb_get();
      if (fb) { addAVIFrame(fb); esp_camera_fb_return(fb); }
      webServer.handleClient();  // keep web responsive during recording
      // Compensate for SD write + handleClient time to maintain even frame pacing
      unsigned long elapsed = millis() - frameStart;
      if (elapsed < frameIntervalMs) delay(frameIntervalMs - elapsed);
    }
    String path = finishAVIRecording();
    uint32_t fsz = 0;
    if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
    File vf = SD_MMC.open(path.c_str(), FILE_READ);
    fsz = vf ? vf.size() : 0; if (vf) vf.close();
    if (sdMutex) xSemaphoreGive(sdMutex);
    tgEnqueueVideo(path,
      "🎬 AVI Video recorded!\n"
      "📊 Stats:\n"
      "🎞 Frames: "+String(aviFrameCount)+"\n"
      "🎥 Resolution: "+String(aviWidth)+"x"+String(aviHeight)+"\n"
      "📁 Size: "+String(fsz/1024)+" KB\n"
      "⏱ Duration: "+String(secs)+"s\n"
      "💾 Saved to SD");
    Serial.printf("[JOB] Record done, %d frames\n", aviFrameCount);
  }
}

void setup(){
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG,0);
  Serial.begin(115200); delay(1000);
  bootMs = millis();
  Serial.println("\n+======================================+");
  Serial.println("| ESP32-CAM Surveillance System v1.0  |");
  Serial.println("| Motion detection: OFF at boot        |");
  Serial.println("+======================================+");

  // Flash LED: use LEDC PWM so intensity slider works correctly.
  // ledcAttach replaces pinMode - same approach as CameraWebServer setupLedFlash().
  ledcAttach(FLASH_LED_PIN, FLASH_LEDC_FREQ, FLASH_LEDC_RES);
  ledcWrite(FLASH_LED_PIN, 0);  // start off

  preferences.begin("surveil", false);
  motionSensitivity  = preferences.getInt ("motionSens",  MOTION_SENSITIVITY_DEFAULT);
  motionCooldownS    = preferences.getInt ("motionCool",  MOTION_COOLDOWN_DEFAULT_S);
  mdThreshold        = sliderToThreshold(motionSensitivity);
  timelapseActive    = preferences.getBool("tlActive",    false);
  timelapseIntervalS = preferences.getInt ("tlInterval",  30);
  // Load credentials from NVS
  cfgWifiSSID = preferences.getString("wifiSSID", "");
  cfgWifiPass = preferences.getString("wifiPass", "");
  cfgBotToken = preferences.getString("botToken", "");
  cfgChatID   = preferences.getString("chatID",   "");
  preferences.end();  // close NVS namespace; reopen only when writing

  // Allocate motion detection buffers (grayscale only - 80x60 = 4800 bytes each)
  if(psramFound()){
    prevGray=(uint8_t*)ps_malloc(MD_PIXELS);
    currGray=(uint8_t*)ps_malloc(MD_PIXELS);
    Serial.println("[MD] PSRAM buffers OK");
  } else {
    prevGray=(uint8_t*)malloc(MD_PIXELS);
    currGray=(uint8_t*)malloc(MD_PIXELS);
    Serial.println("[MD] DRAM buffers OK");
  }
  if(!prevGray||!currGray) Serial.println("⚠ Motion buffer alloc failed");

  // Create SD mutex and Telegram queue/semaphore before any SD or WiFi use
  sdMutex  = xSemaphoreCreateMutex();
  tgBusySem = xSemaphoreCreateBinary();
  if (tgBusySem) xSemaphoreGive(tgBusySem);  // start in "not busy" state
  tgQueue  = xQueueCreate(4, sizeof(TgJob));
  if(!sdMutex || !tgQueue || !tgBusySem) Serial.println("[RTOS] Queue/Mutex/Sem alloc FAILED");

  if(!initCamera()){ Serial.println("[FATAL] Camera failed"); while(true) delay(1000); }

  if(!initSD()){
    Serial.println("⚠ No SD - media disabled");
  } else {
    SD_MMC.mkdir("/photos"); SD_MMC.mkdir("/videos");
    photoCount=countPhotos(); videoCount=countVideos();
    Serial.printf("[SD] %d photos, %d videos\n",photoCount,videoCount);
  }

  // Try STA mode if credentials exist
  if (cfgWifiSSID.length() > 0) {
    WiFi.mode(WIFI_STA);
    WiFi.begin(cfgWifiSSID.c_str(), cfgWifiPass.c_str());
    Serial.printf("[WiFi] Connecting to %s", cfgWifiSSID.c_str());
    for (int i = 0; i < 30 && WiFi.status() != WL_CONNECTED; i++) {
      delay(500); Serial.print(".");
    }
    Serial.println();
  }

  if (WiFi.status() == WL_CONNECTED) {
    apMode = false;
    Serial.println("[WiFi] Connected  IP: " + WiFi.localIP().toString());
    configTime(0, 0, NTP_SERVER);           // fetch UTC from NTP
    setenv("TZ", POSIX_TZ, 1);             // apply local timezone + DST rules
    tzset();
    delay(1500);
    // Init Telegram if credentials saved
    if (cfgBotToken.length() > 0 && cfgChatID.length() > 0) {
      telegramEnabled = true;
      securedClient.setCACert(TELEGRAM_CERTIFICATE_ROOT);
      bot = new UniversalTelegramBot(cfgBotToken.c_str(), securedClient);
      delay(2000);
      tgSend(
        "\xF0\x9F\x9A\x80 *Hellboy's WatchTower v1.0 Online!*\n\n"
        "\xF0\x9F\x93\xA1 IP: " + WiFi.localIP().toString() + "\n"
        "\xF0\x9F\x8F\xA0 Dashboard: http://" + WiFi.localIP().toString() + "\n"
        "\xF0\x9F\x93\xB6 WiFi: " + String(WiFi.RSSI()) + " dBm\n"
        "\xF0\x9F\x93\xB8 Photos on SD: " + String(photoCount) + "\n"
        "\xF0\x9F\x8E\xAC Videos on SD: " + String(videoCount) + "\n"
        "\xF0\x9F\x94\x95 Motion Detection: OFF (send /arm to enable)\n"
        "\xF0\x9F\x8E\xA5 Stream: VGA @10fps\n\n"
        "Send /help for all commands."
      );
      Serial.println("[TG] Bot ready");
      xTaskCreatePinnedToCore(
        telegramTask, "tgTask",
        16384, nullptr, 1, nullptr, 0);
      Serial.println("[RTOS] Telegram task started on Core 0");
    } else {
      Serial.println("[TG] No credentials - Telegram disabled");
      // Still start task so queue drains cleanly if credentials added later
      xTaskCreatePinnedToCore(
        telegramTask, "tgTask",
        16384, nullptr, 1, nullptr, 0);
    }
  } else {
    // No WiFi - start AP mode
    apMode = true;
    WiFi.mode(WIFI_AP);
    WiFi.softAP(AP_SSID, AP_PASS);
    delay(500);
    Serial.println("[WiFi] AP mode started");
    Serial.println("[WiFi] SSID: " AP_SSID "  Pass: " AP_PASS);
    Serial.println("[WiFi] Dashboard: http://" AP_IP_STR);
    // Start Telegram task anyway (queue must always be drained)
    xTaskCreatePinnedToCore(
      telegramTask, "tgTask",
      16384, nullptr, 1, nullptr, 0);
  }

  initWebServer();
  startStreamServer();

  Serial.println("[SYS] All systems GO");
  if (apMode) {
    Serial.println("[SYS] Mode: ACCESS POINT  SSID: " AP_SSID);
    Serial.println("[SYS] Dashboard -> http://" AP_IP_STR);
  } else {
    Serial.printf("[SYS] Mode: STA  IP: %s\n", WiFi.localIP().toString().c_str());
    Serial.printf("[SYS] Dashboard -> http://%s\n", WiFi.localIP().toString().c_str());
  }
  Serial.printf("[MD]  Threshold=%.2f  Cooldown=%ds  Warmup=%d frames\n",
    mdThreshold, motionCooldownS, MD_WARMUP_FRAMES);
}

// ============================================================
//  MAIN LOOP
// ============================================================
void loop(){
  webServer.handleClient();
  executePendingJob();  // run any queued photo/record job

  // WiFi reconnection watchdog (STA mode only)
  // If the router reboots or signal drops, attempt reconnect every 30 seconds.
  if (!apMode && WiFi.status() != WL_CONNECTED) {
    static unsigned long lastReconnectMs = 0;
    unsigned long now = millis();
    if (now - lastReconnectMs >= 30000) {
      lastReconnectMs = now;
      Serial.println("[WiFi] Connection lost - attempting reconnect...");
      WiFi.disconnect();
      WiFi.begin(cfgWifiSSID.c_str(), cfgWifiPass.c_str());
      // Wait up to 10 s for reconnect without blocking motion/web entirely
      for (int i = 0; i < 20 && WiFi.status() != WL_CONNECTED; i++) {
        delay(500);
        webServer.handleClient();
      }
      if (WiFi.status() == WL_CONNECTED) {
        Serial.println("[WiFi] Reconnected  IP: " + WiFi.localIP().toString());
        // Re-sync NTP after reconnect
        configTime(0, 0, NTP_SERVER);
        setenv("TZ", POSIX_TZ, 1);
        tzset();
        tgSend("WiFi reconnected. IP: " + WiFi.localIP().toString());
      } else {
        Serial.println("[WiFi] Reconnect failed - will retry in 30s");
      }
    }
  }

  // Motion detection block
  // Skipped entirely when: disarmed, recording, or within cooldown window
  if(motionArmed && !aviRecording){
    unsigned long now=millis();
    unsigned long coolMs=(unsigned long)(motionCooldownS*1000);

    if(now - lastMotionMs > coolMs){
      camera_fb_t* fb=esp_camera_fb_get();
      if(fb){
        bool motion=checkMotion(fb);
        esp_camera_fb_return(fb);

        if(motion){
          lastMotionMs=now;
          Serial.println("🏃 *** CONFIRMED ***");

          // Brief flash to illuminate scene
          ledcWrite(FLASH_LED_PIN, 255); delay(80); ledcWrite(FLASH_LED_PIN, ledDuty);

          // captureAndSavePhoto sends the photo WITH the caption - no second message needed
          captureAndSavePhoto(true,"Motion Detection",false);
        }
      }
    }
  }

  // Timelapse block
  // Skipped when: inactive, recording, or a job is already pending.
  // Uses captureAndSavePhoto() silently (no Telegram, no flash) so it
  // never interferes with motion alerts or manual captures.
  if (timelapseActive && !aviRecording && pendingJob.type == JOB_NONE) {
    unsigned long now = millis();
    unsigned long tlMs = (unsigned long)(timelapseIntervalS * 1000UL);
    if (now - lastTimelapseMs >= tlMs) {
      lastTimelapseMs = now;
      Serial.printf("[TL] Capturing timelapse frame #%d\n", photoCount + 1);
      captureAndSavePhoto(false, "Timelapse", false);
    }
  }

  // OPT: Dynamic end-of-loop yield.
  // - Skip the delay entirely when a job is queued (execute it immediately next iteration).
  // - Use vTaskDelay() instead of delay() so FreeRTOS can schedule other tasks
  //   (telegramTask, IDLE0 watchdog) during the yield rather than busy-waiting.
  // - When motion is armed and inside the cooldown window, yield only 10ms so
  //   we can process webServer clients quickly without wasting time on a fixed 30ms stall.
  if (pendingJob.type != JOB_NONE) {
    // Work is waiting - don't delay at all, fall through to next loop() immediately
  } else if (motionArmed && !aviRecording) {
    vTaskDelay(pdMS_TO_TICKS(10));  // armed: stay responsive, ~100Hz check rate
  } else {
    vTaskDelay(pdMS_TO_TICKS(30));  // idle: ~33Hz, yields to WiFi + TG task
  }
}

