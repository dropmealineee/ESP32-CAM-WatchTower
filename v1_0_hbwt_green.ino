// -- Telegram background task -----------------------------------
// All Telegram I/O runs on Core 0. loop() on Core 1 never blocks.
typedef enum { TG_TEXT, TG_PHOTO, TG_VIDEO } TgJobType;
// OPT: union payload - path/caption and text are mutually exclusive by job type.
// Saves ~640 bytes per queue slot = ~3.5KB total queue SRAM vs the old flat struct.
struct TgJob {
  TgJobType type;
  union {
    struct {
      char path[128];    // SD path (PHOTO/VIDEO jobs)
      char caption[384]; // caption (PHOTO/VIDEO jobs) - was 512, trimmed to fit union
    };
    char text[512];      // body (TG_TEXT jobs)
  };
};
static QueueHandle_t     tgQueue    = nullptr;  // created in setup()
static SemaphoreHandle_t sdMutex    = nullptr;  // guards all SD_MMC calls
static SemaphoreHandle_t tgBusySem  = nullptr;  // binary sem: taken while TLS send in progress
// tgBusySem serialises all TLS operations within telegramTask.
// Only one mbedTLS session runs at a time - two simultaneous sessions
// exhaust heap and cause silent failures.

// -- Pending-job state machine (Item 5) -------------------------
// HTTP handlers are called from webServer.handleClient() on the main
// task. Heavy work (photo/record) sets a pending flag and returns
// immediately so handleClient() never blocks for 2-30 seconds.
// loop() checks and executes pending jobs each iteration.
typedef enum { JOB_NONE, JOB_PHOTO, JOB_RECORD } PendingJobType;
struct PendingJob {
  PendingJobType type     = JOB_NONE;
  bool           flash    = false;
  int            recSecs  = 10;
};
static volatile PendingJob pendingJob;


