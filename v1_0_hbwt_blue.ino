void apiSdStats() {
  uint64_t tot=SD_MMC.totalBytes(), used=SD_MMC.usedBytes();
  String t="Unknown";
  switch(SD_MMC.cardType()){
    case CARD_MMC:  t="MMC";        break;
    case CARD_SD:   t="SDSC";       break;
    case CARD_SDHC: t="SDHC/SDXC"; break;
    default: break;
  }
  StaticJsonDocument<192> doc;
  doc["sdType"]  = t;
  doc["sdTotal"] = (uint32_t)(tot/1048576);
  doc["sdUsed"]  = (uint32_t)(used/1048576);
  doc["sdFree"]  = (uint32_t)((tot-used)/1048576);
  String out; serializeJson(doc,out);
  webServer.send(200,"application/json",out);
}


