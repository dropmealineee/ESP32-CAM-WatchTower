// Convert slider 1-100 -> float threshold (inverse: high slider = low threshold)
inline float sliderToThreshold(int s) {
  // slider 1   -> ~13.88  (least sensitive, barely triggers)
  // slider 50  ->   8.0   (default, matches MD_THRESHOLD_DEFAULT)
  // slider 100 ->   2.0   (most sensitive)
  return 14.0f - (s * 12.0f / 100.0f);
}

