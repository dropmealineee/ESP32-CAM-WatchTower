// --- Non-blocking Telegram enqueue helpers ----------------------
void tgEnqueue(const String& msg) {
  if (!tgQueue || !telegramEnabled) return;
  TgJob job; job.type = TG_TEXT;
  strlcpy(job.text, msg.c_str(), sizeof(job.text));
  xQueueSend(tgQueue, &job, 0);
}
void tgEnqueuePhoto(const String& path, const String& cap) {
  if (!tgQueue || !telegramEnabled) return;
  TgJob job; job.type = TG_PHOTO;
  strlcpy(job.path,    path.c_str(), sizeof(job.path));
  strlcpy(job.caption, cap.c_str(),  sizeof(job.caption));
  xQueueSend(tgQueue, &job, 0);
}
void tgEnqueueVideo(const String& path, const String& cap) {
  if (!tgQueue || !telegramEnabled) return;
  TgJob job; job.type = TG_VIDEO;
  strlcpy(job.path,    path.c_str(), sizeof(job.path));
  strlcpy(job.caption, cap.c_str(),  sizeof(job.caption));
  xQueueSend(tgQueue, &job, 0);
}
// Legacy alias: all existing tgSend() call-sites compile unchanged
inline void tgSend(const String& msg) { tgEnqueue(msg); }

// --- Telegram worker - runs forever on Core 0 -------------------
// sendPhotoToTelegram / sendVideoToTelegram called ONLY from here.
void telegramTask(void*) {
  unsigned long lastPollMs = 0;
  for (;;) {
    // Use a 500ms queue timeout so we can also poll for incoming Telegram
    // commands on Core 0 without blocking Core 1's main loop at all.
    TgJob job;
    if (xQueueReceive(tgQueue, &job, pdMS_TO_TICKS(500)) == pdTRUE) {
      if (!bot || !telegramEnabled) { vTaskDelay(pdMS_TO_TICKS(10)); continue; }
      xSemaphoreTake(tgBusySem, portMAX_DELAY);
      switch (job.type) {
        case TG_TEXT:  bot->sendMessage(cfgChatID.c_str(), String(job.text), ""); break;
        case TG_PHOTO: sendPhotoToTelegram(String(job.path), String(job.caption)); break;
        case TG_VIDEO:
          vTaskDelay(pdMS_TO_TICKS(3000));
          sendVideoToTelegram(String(job.path), String(job.caption));
          break;
      }
      xSemaphoreGive(tgBusySem);
      vTaskDelay(pdMS_TO_TICKS(200));
    }

    // Poll for incoming Telegram commands here on Core 0 every 2 seconds.
    // Previously this ran in loop() on Core 1, blocking it with a full
    // HTTPS round-trip every 2s and starving the stream task.
    if (!bot || !telegramEnabled) continue;
    unsigned long now = millis();
    if (now - lastPollMs < 2000) continue;
    lastPollMs = now;
    xSemaphoreTake(tgBusySem, portMAX_DELAY);
    int n = bot->getUpdates(bot->last_message_received + 1);
    xSemaphoreGive(tgBusySem);
    while (n) {
      for (int i = 0; i < n; i++) {
        String text = bot->messages[i].text;
        if (bot->messages[i].chat_id != cfgChatID) continue;
        Serial.println("[TG] " + text);
        if (text == "/help" || text == "/start") {
          bot->sendMessage(cfgChatID.c_str(),
            "\xF0\x9F\x93\xB7 *ESP32-CAM Surveillance - Help Menu*\n\n"
            "\xF0\x9F\x93\xB8 /photo - Capture hi-res photo (no flash)\n"
            "\xE2\x9A\xA1 /photoflash - Capture hi-res photo WITH flash\n"
            "\xF0\x9F\x8E\xA5 /video - Record 10s AVI video\n"
            "\xF0\x9F\x8E\xAC /record30 - Record 30s AVI video\n"
            "\xF0\x9F\x93\x8A /status - Full system status\n"
            "\xF0\x9F\x94\x92 /arm - Arm motion detection\n"
            "\xF0\x9F\x94\x93 /disarm - Disarm motion detection\n"
            "\xF0\x9F\x92\xBE /storage - SD card storage info\n"
            "\xF0\x9F\x94\x84 /restart - Restart the ESP32\n"
            "\xE2\x9D\x93 /help - Show this menu\n\n"
            "\xF0\x9F\x92\xA1 _Dashboard: http://" + WiFi.localIP().toString() + "_", "Markdown");
        }
        else if (text == "/photo") {
          tgSend("\xF0\x9F\x93\xB8 Capturing hi-res photo (no flash)...");
          pendingJob.flash = false; pendingJob.type = JOB_PHOTO;
        }
        else if (text == "/photoflash") {
          tgSend("\xE2\x9A\xA1 Capturing hi-res photo WITH flash...");
          pendingJob.flash = true; pendingJob.type = JOB_PHOTO;
        }
        else if (text == "/video")    { pendingJob.recSecs = 10; pendingJob.type = JOB_RECORD; }
        else if (text == "/record30") { pendingJob.recSecs = 30; pendingJob.type = JOB_RECORD; }
        else if (text == "/status") {
          float temp = temperatureRead();
          unsigned long lm = (millis() - lastMotionMs) / 1000;
          bot->sendMessage(cfgChatID.c_str(),
            "\xF0\x9F\x8C\x90 *Network Status:*\n"
            "\xF0\x9F\x93\xB6 WiFi: Connected \xE2\x9C\x85\n"
            "\xF0\x9F\x93\xB1 IP: " + WiFi.localIP().toString() + "\n"
            "\xF0\x9F\x93\xA1 RSSI: " + String(WiFi.RSSI()) + " dBm\n"
            "\xF0\x9F\x8C\xA1 Temp: " + String(temp, 1) + " degC\n\n"
            "\xF0\x9F\x93\xB7 *Camera:*\n"
            "\xF0\x9F\x8E\xA5 Stream: " + getResLabel(streamFrameSize) + " @" + String(streamFps) + "fps\n"
            "\xF0\x9F\x93\xB8 Photos: " + String(photoCount) + "\n"
            "\xF0\x9F\x94\xB4 Recording: " + (aviRecording ? "ACTIVE" : "IDLE") + "\n\n"
            "\xF0\x9F\x8F\x83 *Motion Detection:*\n"
            "\xF0\x9F\x94\x8D Status: " + (motionArmed ? "ARMED \xF0\x9F\x9F\xA2" : "DISARMED \xF0\x9F\x94\xB4") + "\n"
            "\xF0\x9F\x8E\x9A Sensitivity: " + String(motionSensitivity) + "\n"
            "\xE2\x8F\xB1 Cooldown: " + String(motionCooldownS) + "s\n"
            "\xF0\x9F\x95\x90 Last alert: " + String(lm) + "s ago", "Markdown");
        }
        else if (text == "/arm")    { armMotion();    tgSend("\xF0\x9F\x94\x92 Motion *ARMED* \xF0\x9F\x9F\xA2"); }
        else if (text == "/disarm") { disarmMotion(); tgSend("\xF0\x9F\x94\x93 Motion *DISARMED*"); }
        else if (text == "/storage") {
          uint64_t tot = SD_MMC.totalBytes(), used = SD_MMC.usedBytes();
          String sdt = "Unknown";
          switch (SD_MMC.cardType()) {
            case CARD_MMC:  sdt = "MMC";        break;
            case CARD_SD:   sdt = "SDSC";       break;
            case CARD_SDHC: sdt = "SDHC/SDXC"; break;
            default: break;
          }
          bot->sendMessage(cfgChatID.c_str(),
            "\xF0\x9F\x92\xBE *SD Card:*\n"
            "Type: " + sdt + "\n"
            "Total: " + String((uint32_t)(tot / (1024*1024))) + " MB\n"
            "Used: "  + String((uint32_t)(used / (1024*1024))) + " MB\n"
            "Free: "  + String((uint32_t)((tot-used) / (1024*1024))) + " MB\n"
            "Photos: " + String(photoCount) + "  Videos: " + String(videoCount), "Markdown");
        }
        else if (text == "/restart") {
          tgSend("\xF0\x9F\x94\x84 Restarting now...");
          vTaskDelay(pdMS_TO_TICKS(500)); ESP.restart();
        }
        else { tgSend("\xE2\x9D\x93 Unknown command. Send /help for menu."); }
      }
      xSemaphoreTake(tgBusySem, portMAX_DELAY);
      n = bot->getUpdates(bot->last_message_received + 1);
      xSemaphoreGive(tgBusySem);
    }
  }
}


void sendPhotoToTelegram(const String& filePath, const String& caption) {
  if (!telegramEnabled) return;

  // Step 1: get file size under mutex (fast - just a stat)
  if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  File fSize = SD_MMC.open(filePath.c_str(), FILE_READ);
  size_t sz = fSize ? fSize.size() : 0;
  if (fSize) fSize.close();
  if (sdMutex) xSemaphoreGive(sdMutex);
  if (sz == 0) { Serial.println("[TG] Photo: file not found or empty"); return; }

  // Step 2: TLS connect (1-3s) - NO mutex held, main loop runs freely
  // Retry up to 3 times with 2s delay - camera reinit can briefly disturb WiFi stack
  WiFiClientSecure cl; cl.setCACert(TELEGRAM_CERTIFICATE_ROOT);
  bool tlsOk = false;
  for (int attempt = 1; attempt <= 3; attempt++) {
    if (cl.connect("api.telegram.org", 443, 15000)) { tlsOk = true; break; }
    Serial.printf("[TG] Photo: TLS connect failed (attempt %d/3)\n", attempt);
    if (attempt < 3) { cl.stop(); delay(2000); }
  }
  if (!tlsOk) { Serial.println("[TG] Photo: all TLS attempts failed"); return; }


  // Step 3: send HTTP headers
  const String bd = "ESP32PB123";
  String head =
    "--"+bd+"\r\nContent-Disposition: form-data; name=\"chat_id\"\r\n\r\n"+cfgChatID+"\r\n"
    "--"+bd+"\r\nContent-Disposition: form-data; name=\"caption\"\r\n\r\n"+caption+"\r\n"
    "--"+bd+"\r\nContent-Disposition: form-data; name=\"photo\"; filename=\"p.jpg\"\r\n"
    "Content-Type: image/jpeg\r\n\r\n";
  String tail = "\r\n--"+bd+"--\r\n";
  cl.printf("POST /bot%s/sendPhoto HTTP/1.1\r\nHost: api.telegram.org\r\n"
            "Content-Type: multipart/form-data; boundary=%s\r\n"
            "Content-Length: %u\r\nConnection: close\r\n\r\n",
            cfgBotToken.c_str(), bd.c_str(), (unsigned)(head.length()+sz+tail.length()));
  cl.print(head);

  // Step 4: stream file bytes - take mutex only for the SD read portion
  // OPT: Use 8KB chunks instead of 1KB to reduce mutex lock/unlock cycles
  // from ~200 to ~25 for a typical 200KB photo. SD bus is idle during cl.write()
  // so the tight acquire-read-release-write-acquire loop was pure overhead.
  if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  File f = SD_MMC.open(filePath.c_str(), FILE_READ);
  if (!f) { if(sdMutex) xSemaphoreGive(sdMutex); cl.stop(); return; }
  uint8_t buf[8192];
  while (f.available()) {
    int n = f.read(buf, sizeof(buf));
    if (sdMutex) xSemaphoreGive(sdMutex);
    cl.write(buf, n);               // TLS write outside mutex
    if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  }
  f.close();
  if (sdMutex) xSemaphoreGive(sdMutex);

  // Step 5: send closing boundary and drain response
  cl.print(tail);
  unsigned long t=millis(); while(!cl.available()&&millis()-t<15000) delay(10);
  while(cl.available()) cl.read();
  cl.stop();
  Serial.println("[TG] Photo sent OK");
}

void sendVideoToTelegram(const String& filePath, const String& caption) {
  if (!telegramEnabled) return;
  String fname = filePath.substring(filePath.lastIndexOf('/')+1);

  // Step 1: get file size under mutex
  if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  File fSize = SD_MMC.open(filePath.c_str(), FILE_READ);
  size_t sz = fSize ? fSize.size() : 0;
  if (fSize) fSize.close();
  if (sdMutex) xSemaphoreGive(sdMutex);
  if (sz == 0) { Serial.println("[TG] Video: file not found or empty"); return; }

  // Step 2: TLS connect - no mutex held
  // Retry up to 3 times with 2s delay - camera reinit can briefly disturb WiFi stack
  WiFiClientSecure cl; cl.setCACert(TELEGRAM_CERTIFICATE_ROOT);
  bool tlsOk = false;
  for (int attempt = 1; attempt <= 3; attempt++) {
    if (cl.connect("api.telegram.org", 443, 20000)) { tlsOk = true; break; }
    Serial.printf("[TG] Video: TLS connect failed (attempt %d/3)\n", attempt);
    if (attempt < 3) { cl.stop(); delay(2000); }
  }
  if (!tlsOk) { Serial.println("[TG] Video: all TLS attempts failed"); return; }


  // Step 3: send HTTP headers
  const String bd = "ESP32VB456";
  String head =
    "--"+bd+"\r\nContent-Disposition: form-data; name=\"chat_id\"\r\n\r\n"+cfgChatID+"\r\n"
    "--"+bd+"\r\nContent-Disposition: form-data; name=\"caption\"\r\n\r\n"+caption+"\r\n"
    "--"+bd+"\r\nContent-Disposition: form-data; name=\"document\"; filename=\""+fname+"\"\r\n"
    "Content-Type: video/x-msvideo\r\n\r\n";
  String tail = "\r\n--"+bd+"--\r\n";
  cl.printf("POST /bot%s/sendDocument HTTP/1.1\r\nHost: api.telegram.org\r\n"
            "Content-Type: multipart/form-data; boundary=%s\r\n"
            "Content-Length: %u\r\nConnection: close\r\n\r\n",
            cfgBotToken.c_str(), bd.c_str(), (unsigned)(head.length()+sz+tail.length()));
  cl.print(head);

  // Step 4: stream file bytes - release mutex between chunks
  // vTaskDelay every 20 chunks feeds the watchdog on Core 0 during long uploads.
  if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  File f = SD_MMC.open(filePath.c_str(), FILE_READ);
  if (!f) { if(sdMutex) xSemaphoreGive(sdMutex); cl.stop(); return; }
  uint8_t buf[2048];
  int chunkCount = 0;
  while (f.available()) {
    int n = f.read(buf, sizeof(buf));
    if (sdMutex) xSemaphoreGive(sdMutex);
    cl.write(buf, n);
    chunkCount++;
    if (chunkCount % 20 == 0) {
      vTaskDelay(pdMS_TO_TICKS(10));  // yield to IDLE0 - feeds task watchdog
    }
    if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  }
  f.close();
  if (sdMutex) xSemaphoreGive(sdMutex);

  // Step 5: closing boundary and drain
  cl.print(tail);
  unsigned long t=millis(); while(!cl.available()&&millis()-t<30000) delay(10);
  while(cl.available()) cl.read();
  cl.stop();
  Serial.println("[TG] Video sent OK");
}

// ============================================================
//  PHOTO CAPTURE - safe high-resolution still
//
//  Strategy: deinit camera ? reinit at UXGA ? capture ? reinit
//  back to stream config. This is the ONLY way to switch resolution
//  reliably on this hardware without FB-OVF errors.
//
//  Stream is stopped before deinit and restored after reinit.
// ============================================================
bool captureAndSavePhoto(bool sendTg, String triggerLabel, bool useFlash) {
  // -- 1. Stop stream and disarm motion ---------------------
  bool wasStreaming = streamActive;
  bool wasArmed     = motionArmed;
  streamActive = false;
  motionArmed  = false;
  delay(200);   // give httpd stream task time to finish its current frame

  // -- 2. Reinit camera at SVGA for reliable high-res still -----
  // SVGA (800x600, quality=8): 2x VGA area, fast AE settle, no blank frames.
  // UXGA was tried but caused blank frames on this hardware due to PSRAM limits.
  bool reinitOk = initCameraMode(PHOTO_FRAMESIZE, PHOTO_JPEG_QUALITY, 1);
  if (!reinitOk) {
    Serial.println("[CAM] Photo reinit failed, trying VGA fallback");
    reinitOk = initCameraMode(FRAMESIZE_VGA, PHOTO_JPEG_QUALITY, 1);
  }
  delay(350);   // OV2640 AE/AWB needs time to settle at new resolution

  // -- 3. Warm-up: discard 3 frames so AE/AWB fully settles ----
  for (int i = 0; i < 3; i++) {
    camera_fb_t* flush = esp_camera_fb_get();
    if (flush) esp_camera_fb_return(flush);
    delay(120);
  }

  // -- 4. Flash on -> discard pre-flash buffer -> capture -> flash off ----
  //
  // The OV2640 JPEG pipeline is double-buffered. When you turn the flash on
  // and immediately call esp_camera_fb_get(), you receive the frame that was
  // ALREADY being exposed before the flash fired. You need to:
  //   a) Turn flash ON
  //   b) Discard one frame (the one exposed without flash)
  //   c) Capture the next frame (now fully lit by the flash)
  //   d) Turn flash OFF
  //
  if (useFlash) {
    ledcWrite(FLASH_LED_PIN, 255);
    delay(50);   // let flash reach full brightness
    // Discard the frame that was buffered before flash fired
    camera_fb_t* preflash = esp_camera_fb_get();
    if (preflash) esp_camera_fb_return(preflash);
    delay(30);   // one extra frame period at ~15fps
  }
  camera_fb_t* fb = esp_camera_fb_get();
  if (useFlash) {
    ledcWrite(FLASH_LED_PIN, ledDuty);  // restore previous duty after flash
  }

  // -- 5. Save to SD -----------------------------------------
  bool ok = false;
  String path = "";
  if (fb) {
    if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
    SD_MMC.mkdir("/photos");
    path = "/photos/" + getTimestamp() + ".jpg";
    File out = SD_MMC.open(path.c_str(), FILE_WRITE);
    if (out) {
      out.write(fb->buf, fb->len);
      out.close();
      ok = true;
    }
    if (sdMutex) xSemaphoreGive(sdMutex);
    Serial.printf("[CAM] Saved %s (%u bytes, flash=%d)\n",
                  path.c_str(), (unsigned)fb->len, (int)useFlash);
    esp_camera_fb_return(fb);
    photoCount++;  // increment in-place; full rescan only at boot / deleteAllSD()
  } else {
    Serial.println("[CAM] Capture failed - fb==NULL");
  }

  // -- 6. Reinit camera back to stream mode -----------------
  {
    int fbCount = psramFound() ? 2 : 1;
    initCameraMode((framesize_t)streamFrameSize, STREAM_JPEG_QUALITY, fbCount);
  }
  delay(150);

  // Restore stream and motion state
  streamActive = wasStreaming;
  motionArmed  = wasArmed;
  if (wasArmed) { prevFrameReady = false; }   // reset motion baseline

  // -- 7. Send to Telegram with combined caption -------------
  if (ok && sendTg && telegramEnabled && bot) {
    String cap =
      "📸 Photo captured!\n"
      "📊 Photo #" + String(photoCount) + "\n"
      "💾 Saved to SD ✅\n"
      "⚡ Flash: " + (useFlash ? "ON" : "OFF") + "\n"
      "🔖 Trigger: " + triggerLabel;
    tgEnqueuePhoto(path, cap);
  }
  return ok;
}

// ============================================================
//  AVI WRITER
// ============================================================
static void writeU32LE(File& f, uint32_t v) {
  uint8_t b[4]={(uint8_t)v,(uint8_t)(v>>8),(uint8_t)(v>>16),(uint8_t)(v>>24)};
  f.write(b,4);
}
static void writeTag(File& f, const char* t){ f.write((const uint8_t*)t,4); }

// Extract actual pixel dimensions from a JPEG frame by scanning for SOF marker.
// This is the only reliable way to know the true frame size - the camera
// config framesize_t gives nominal sizes, but the actual JPEG may differ.
// OPT: Limit scan to first 512 bytes. In a well-formed OV2640 JPEG the SOF
// marker (FF C0/C2) appears within the first ~200 bytes after APP0/APP1.
// Scanning the full frame (10-30KB) risked hitting 0xFF bytes in pixel data.
static bool jpegGetDimensions(const uint8_t* buf, size_t len, int& w, int& h) {
  size_t scanLen = (len < 512) ? len : 512;
  for (size_t i = 0; i + 8 < scanLen; i++) {
    if (buf[i] == 0xFF && (buf[i+1] == 0xC0 || buf[i+1] == 0xC2)) {
      // SOF marker: FF C0/C2 <length(2)> <precision(1)> <height(2)> <width(2)>
      h = (buf[i+5] << 8) | buf[i+6];
      w = (buf[i+7] << 8) | buf[i+8];
      if (w > 0 && h > 0) return true;
    }
  }
  // Fallback: scan full frame if not found in header (non-standard JPEG)
  for (size_t i = 512; i + 8 < len; i++) {
    if (buf[i] == 0xFF && (buf[i+1] == 0xC0 || buf[i+1] == 0xC2)) {
      h = (buf[i+5] << 8) | buf[i+6];
      w = (buf[i+7] << 8) | buf[i+8];
      if (w > 0 && h > 0) return true;
    }
  }
  return false;
}

static void patchAVIHeader(File& f, int frames, int fps, int w, int h) {
  f.seek(0);
  if(fps<1)fps=1; if(fps>30)fps=30;
  uint32_t usf = 1000000u / (uint32_t)fps;
  const uint32_t avihSz=56, strhSz=56, strfSz=40;
  uint32_t strlBody = 4 + (4+4+strhSz) + (4+4+strfSz);
  uint32_t hdrlBody = 4 + (4+4+avihSz) + (4+4+strlBody);
  uint32_t maxBytes = (uint32_t)w * h * 3;

  // RIFF AVI header
  writeTag(f,"RIFF"); writeU32LE(f,(uint32_t)f.size()-8); writeTag(f,"AVI ");

  // hdrl LIST
  writeTag(f,"LIST"); writeU32LE(f,hdrlBody); writeTag(f,"hdrl");

  // avih - Main AVI header (56 bytes)
  writeTag(f,"avih"); writeU32LE(f,avihSz);
  writeU32LE(f,usf);          // dwMicroSecPerFrame
  writeU32LE(f,maxBytes);     // dwMaxBytesPerSec
  writeU32LE(f,0);            // dwPaddingGranularity
  writeU32LE(f,0x00);         // dwFlags: 0 (no idx1 chunk written, so AVIF_HASINDEX must NOT be set)
  writeU32LE(f,(uint32_t)frames); // dwTotalFrames
  writeU32LE(f,0);            // dwInitialFrames
  writeU32LE(f,1);            // dwStreams
  writeU32LE(f,maxBytes);     // dwSuggestedBufferSize
  writeU32LE(f,(uint32_t)w);  // dwWidth
  writeU32LE(f,(uint32_t)h);  // dwHeight
  for(int i=0;i<4;i++) writeU32LE(f,0); // reserved[4]

  // strl LIST (stream list)
  writeTag(f,"LIST"); writeU32LE(f,strlBody); writeTag(f,"strl");

  // strh - Stream header (56 bytes)
  writeTag(f,"strh"); writeU32LE(f,strhSz);
  writeTag(f,"vids");         // fccType: video stream
  writeTag(f,"MJPG");         // fccHandler: MJPEG codec
  writeU32LE(f,0);            // dwFlags
  writeU32LE(f,0);            // wPriority + wLanguage
  writeU32LE(f,0);            // dwInitialFrames
  writeU32LE(f,1);            // dwScale (time base numerator)
  writeU32LE(f,(uint32_t)fps);// dwRate  (frames per second)
  writeU32LE(f,0);            // dwStart
  writeU32LE(f,(uint32_t)frames); // dwLength
  writeU32LE(f,maxBytes);     // dwSuggestedBufferSize
  writeU32LE(f,0xFFFFFFFF);   // dwQuality (-1 = default)
  writeU32LE(f,0);            // dwSampleSize (0 = variable)
  // rcFrame: {left=0, top=0, right=w, bottom=h} as two 32-bit LE words
  writeU32LE(f,0);                          // left(16) | top(16)
  writeU32LE(f,((uint32_t)h<<16)|(uint32_t)w); // right(16) | bottom(16) -- actually bottom(16)|right(16)

  // strf - BITMAPINFOHEADER (40 bytes) for MJPEG video stream
  writeTag(f,"strf"); writeU32LE(f,strfSz);
  writeU32LE(f,strfSz);            // biSize
  writeU32LE(f,(uint32_t)w);       // biWidth
  // biHeight: NEGATIVE value signals top-down row order (required for MJPEG).
  // Without this, many players assume bottom-up and display incorrectly.
  // Store as two's complement uint32.
  writeU32LE(f,(uint32_t)(-(int32_t)h)); // biHeight (negative = top-down)
  writeU32LE(f,1u|(24u<<16));      // biPlanes=1, biBitCount=24
  writeTag(f,"MJPG");              // biCompression
  writeU32LE(f,maxBytes);          // biSizeImage
  writeU32LE(f,0);                 // biXPelsPerMeter
  writeU32LE(f,0);                 // biYPelsPerMeter
  writeU32LE(f,0);                 // biClrUsed
  writeU32LE(f,0);                 // biClrImportant
}

#define AVI_HDR_RESERVE 256
bool startAVIRecording(int durationSec) {
  if(aviRecording) return false;
  // Check free space: estimate ~150 MB max for a 120s recording; require at least 200 MB free
  uint64_t freeBytes = SD_MMC.totalBytes() - SD_MMC.usedBytes();
  if (freeBytes < 200ULL * 1024 * 1024) {
    Serial.printf("[AVI] Insufficient SD space: %.0f MB free\n", freeBytes / 1048576.0f);
    tgSend("SD card almost full - recording aborted. Free space: "
      + String((uint32_t)(freeBytes / 1048576)) + " MB");
    return false;
  }
  if (sdMutex) xSemaphoreTake(sdMutex, portMAX_DELAY);
  SD_MMC.mkdir("/videos");
  // Filename: YYYY-MM-DD_HH-MM-SS_<RES>_<DUR>s.avi
  String path = "/videos/" + getTimestamp() + "_" + getResLabel(streamFrameSize)
                + "_" + String(durationSec) + "s.avi";
  strncpy(aviFilePath, path.c_str(), sizeof(aviFilePath)-1);
  aviFile = SD_MMC.open(aviFilePath, FILE_WRITE);
  if(!aviFile){ if(sdMutex) xSemaphoreGive(sdMutex); Serial.println("[AVI] Open failed"); return false; }
  uint8_t zeros[AVI_HDR_RESERVE]={};
  aviFile.write(zeros, AVI_HDR_RESERVE);
  aviMoviOffset = (uint32_t)aviFile.position();
  writeTag(aviFile,"LIST"); writeU32LE(aviFile,0); writeTag(aviFile,"movi");
  aviFrameCount = 0; aviStartMs = millis(); aviRecording = true;
  aviWidth = 640; aviHeight = 480;  // defaults - updated from first real frame
  Serial.printf("[AVI] Start %s\n", aviFilePath);
  return true;
}

bool addAVIFrame(camera_fb_t* fb){
  if(!aviRecording||!fb||aviFrameCount>=AVI_MAX_FRAMES) return false;
  // Extract actual frame dimensions from first frame
  if(aviFrameCount == 0) {
    int fw=0, fh=0;
    if(jpegGetDimensions(fb->buf, fb->len, fw, fh) && fw>0 && fh>0) {
      aviWidth = fw; aviHeight = fh;
      Serial.printf("[AVI] Frame dims from JPEG: %dx%d\n", fw, fh);
    }
  }
  aviFrameCount++;
  writeTag(aviFile,"00dc"); writeU32LE(aviFile,fb->len);
  aviFile.write(fb->buf,fb->len);
  if(fb->len&1) aviFile.write((uint8_t)0);
  return true;
}

String finishAVIRecording(){
  if(!aviRecording) return "";
  aviRecording=false;
  unsigned long dur=millis()-aviStartMs;
  int fps=(dur>0)?(int)((aviFrameCount*1000UL)/dur):5;
  if(fps<1)fps=1; if(fps>30)fps=30;
  uint32_t end=(uint32_t)aviFile.size();
  uint32_t moviBody=end-aviMoviOffset-8;
  aviFile.seek(aviMoviOffset+4); writeU32LE(aviFile,moviBody+4);
  // Use actual detected dimensions - correct aspect ratio in any player
  patchAVIHeader(aviFile, aviFrameCount, fps, aviWidth, aviHeight);
  aviFile.close();
  if (sdMutex) xSemaphoreGive(sdMutex);
  videoCount++;  // increment in-place; full rescan only at boot / deleteAllSD()
  Serial.printf("[AVI] Done %d frames %dfps %dx%d\n",
    aviFrameCount, fps, aviWidth, aviHeight);
  return String(aviFilePath);
}

// ============================================================
//  MOTION DETECTION  - v2.2 complete rewrite
//
//  Algorithm: Mean Absolute Difference (MAD) on grayscale frames
//
//  Why MAD works better than pixel-count:
//    ? JPEG noise causes tiny random differences on EVERY pixel
//    ? Counting "pixels > threshold" catches ALL of them ? floods
//    ? MAD averages all differences ? JPEG noise averages to ~0-3
//    ? Real motion creates large per-pixel differences ? MAD spikes
//
//  Extra guards:
//    1. Warm-up: first MD_WARMUP_FRAMES frames after arming are
//       discarded so the sensor and AE settle (eliminates boot floods)
//    2. Consecutive: motion fires only after MD_CONSEC_REQUIRED
//       successive frames both exceed the threshold (eliminates
//       single-frame compression artefact triggers)
// ============================================================

// Decode JPEG to grayscale at 1/8 scale -> 80x60
// Uses jpg2rgb565 then converts RGB565->gray via a precomputed LUT.
//
// OPT: Two 256-entry lookup tables replace the per-pixel multiply chain.
//   hiLUT[hi] = R contribution + upper-G contribution to BT.601 luma
//   loLUT[lo] = lower-G contribution + B contribution to BT.601 luma
//   luma = clamp(hiLUT[hi] + loLUT[lo], 255)
// Cost per pixel: 2 table lookups + 1 add  (was: 6 shifts, 4 ORs, 3 muls)
// ~40% faster on Xtensa LX6 at 240 MHz.
static bool     grayLUTReady = false;
static uint8_t  hiLUT[256];   // R + upper-G luma contribution indexed by hi byte
static uint8_t  loLUT[256];   // lower-G + B luma contribution indexed by lo byte

static void buildGrayLUT() {
  if (grayLUTReady) return;
  // hi byte layout: RRRRRGGG  (R5 in bits[7:3], G_hi3 in bits[2:0])
  for (int hi = 0; hi < 256; hi++) {
    uint8_t r5  = (hi >> 3) & 0x1F;
    uint8_t gh3 = hi & 0x07;             // top 3 bits of G6
    uint8_t r8  = (r5 << 3) | (r5 >> 2);
    uint8_t g6h = gh3 << 3;              // bottom 3 G bits contributed by loLUT
    uint8_t g8h = (g6h << 2) | (g6h >> 4);
    uint16_t v  = (77u * r8 + 150u * g8h) >> 8;
    hiLUT[hi]   = (uint8_t)(v > 255 ? 255 : v);
  }
  // lo byte layout: GGGBBBBB  (G_lo3 in bits[7:5], B5 in bits[4:0])
  for (int lo = 0; lo < 256; lo++) {
    uint8_t gl3 = (lo >> 5) & 0x07;     // bottom 3 bits of G6
    uint8_t b5  = lo & 0x1F;
    uint8_t b8  = (b5 << 3) | (b5 >> 2);
    uint8_t g6l = gl3;
    uint8_t g8l = (g6l << 2) | (g6l >> 4);
    uint16_t v  = (150u * g8l + 29u * b8) >> 8;
    loLUT[lo]   = (uint8_t)(v > 255 ? 255 : v);
  }
  grayLUTReady = true;
}

static bool decodeToGray(camera_fb_t* fb, uint8_t* grayOut) {
  static uint8_t* rgb565Tmp = nullptr;
  const size_t tmpSz = MD_PIXELS * 2;

  if (!rgb565Tmp) {
    rgb565Tmp = psramFound()
      ? (uint8_t*)ps_malloc(tmpSz)
      : (uint8_t*)malloc(tmpSz);
    if (!rgb565Tmp) {
      Serial.println("[MD] decodeToGray: buffer alloc failed - motion disabled");
      return false;
    }
  }

  buildGrayLUT();  // no-op after first call

  if (!jpg2rgb565(fb->buf, fb->len, rgb565Tmp, JPG_SCALE_8X)) return false;

  // OPT: LUT lookup - 2 reads + 1 add per pixel replaces full multiply chain
  const uint8_t* src = rgb565Tmp;
  for (int i = 0; i < MD_PIXELS; i++) {
    uint16_t luma = (uint16_t)hiLUT[src[0]] + (uint16_t)loLUT[src[1]];
    grayOut[i] = (luma > 255) ? 255 : (uint8_t)luma;
    src += 2;
  }
  return true;
}

bool checkMotion(camera_fb_t* fb) {
  // Guard: armed, buffers ready, not recording
  if (!motionArmed || !prevGray || !currGray) return false;

  // Decode current frame to grayscale
  if (!decodeToGray(fb, currGray)) return false;

  // Warm-up phase: accumulate baseline frames, don't trigger.
  // OPT: Only memcpy on the LAST warm-up frame - previous copies were
  // immediately overwritten by the next frame's decode, so they were wasted.
  if (!mdWarmedUp) {
    mdWarmupCount++;
    if (mdWarmupCount >= MD_WARMUP_FRAMES) {
      // Final warm-up frame: latch it as the baseline and go active
      memcpy(prevGray, currGray, MD_PIXELS);
      prevFrameReady = true;
      mdWarmedUp = true;
      Serial.println("[MD] Warm-up complete - detection active");
    } else {
      Serial.printf("[MD] Warm-up %d/%d\n", mdWarmupCount, MD_WARMUP_FRAMES);
    }
    return false;
  }

  if (!prevFrameReady) {
    memcpy(prevGray, currGray, MD_PIXELS);
    prevFrameReady = true;
    return false;
  }

  // Compute Mean Absolute Difference across all pixels
  uint32_t sumDiff = 0;
  for (int i = 0; i < MD_PIXELS; i++) {
    sumDiff += (uint32_t)abs((int)currGray[i] - (int)prevGray[i]);
  }
  float mad = (float)sumDiff / MD_PIXELS;

  // Update previous frame
  memcpy(prevGray, currGray, MD_PIXELS);

  // Throttle serial output: print idle MAD at most once every 5 seconds
  static unsigned long lastMadPrintMs = 0;
  if (millis() - lastMadPrintMs >= 5000) {
    Serial.printf("[MD] MAD=%.2f threshold=%.2f\n", mad, mdThreshold);
    lastMadPrintMs = millis();
  }

  // Check against threshold
  if (mad > mdThreshold) {
    mdConsecutive++;
    Serial.printf("[MD] Hit %d/%d (MAD=%.2f)\n",
      mdConsecutive, MD_CONSEC_REQUIRED, mad);
    if (mdConsecutive >= MD_CONSEC_REQUIRED) {
      mdConsecutive = 0;   // reset for next event
      return true;         // REAL MOTION CONFIRMED
    }
  } else {
    // Reset consecutive counter if frame is calm
    mdConsecutive = 0;
  }
  return false;
}

// ============================================================
//  MJPEG STREAM SERVER  (port 81)
// ============================================================
#define STREAM_BD "ESP32SBound"
static const char* STREAM_CT   = "multipart/x-mixed-replace;boundary=" STREAM_BD;
// X-Timestamp matches CameraWebServer format - some clients use it for sync
static const char* STREAM_PART = "Content-Type: image/jpeg\r\nContent-Length: %u\r\nX-Timestamp: %d.%06d\r\n\r\n";

static esp_err_t streamHandler(httpd_req_t* req) {
  if (!streamActive) { httpd_resp_send_404(req); return ESP_OK; }
  httpd_resp_set_type(req, STREAM_CT);
  httpd_resp_set_hdr(req, "Access-Control-Allow-Origin", "*");
  httpd_resp_set_hdr(req, "X-Framerate", "60");
  const char* bnd = "\r\n--" STREAM_BD "\r\n";
  char hdr[128];  // enlarged to fit X-Timestamp

  int64_t frameIntervalUs = (streamFps > 0) ? (1000000 / streamFps) : 100000;
  int64_t lastFrameUs = esp_timer_get_time();

  while (streamActive) {
    camera_fb_t* fb = esp_camera_fb_get();
    if (!fb) break;
    httpd_resp_send_chunk(req, bnd, strlen(bnd));
    size_t hl = snprintf(hdr, sizeof(hdr), STREAM_PART, fb->len,
                         (int)fb->timestamp.tv_sec, (int)fb->timestamp.tv_usec);
    httpd_resp_send_chunk(req, hdr, hl);
    esp_err_t r = httpd_resp_send_chunk(req, (const char*)fb->buf, fb->len);
    esp_camera_fb_return(fb);
    if (r != ESP_OK) break;
    int64_t now = esp_timer_get_time();
    int64_t elapsed = now - lastFrameUs;
    if (elapsed < frameIntervalUs) {
      vTaskDelay(pdMS_TO_TICKS((frameIntervalUs - elapsed) / 1000));
    }
    lastFrameUs = esp_timer_get_time();
  }
  return ESP_OK;
}

void startStreamServer() {
  httpd_config_t cfg = HTTPD_DEFAULT_CONFIG();
  cfg.server_port    = 81;
  cfg.ctrl_port      = 32769;
  cfg.max_uri_handlers = 2;
  cfg.stack_size     = 8192;   // CameraWebServer uses 8KB stack for stream task
  cfg.send_wait_timeout = 10;  // seconds - prevents slow clients from blocking
  httpd_uri_t u = {"/stream", HTTP_GET, streamHandler, nullptr};
  if (httpd_start(&streamHttpd, &cfg) == ESP_OK) {
    httpd_register_uri_handler(streamHttpd, &u);
    Serial.println("[STREAM] :81/stream ready");
  }
}

