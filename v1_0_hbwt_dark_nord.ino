void apiStreamStart() {
  // Accept optional res/fps overrides from the start request
  if (webServer.hasArg("res")) {
    int r = webServer.arg("res").toInt();
    if (r >= 0 && r <= 13) { streamFrameSize = r; }
  }
  if (webServer.hasArg("fps")) {
    int f = webServer.arg("fps").toInt();
    if (f >= 1 && f <= 30) { streamFps = f; }
  }
  // Stop stream while we reinit camera (safe - nothing streaming yet)
  streamActive = false;
  delay(100);
  applyStreamResolution();
  delay(150);
  streamActive = true;
  webServer.send(200,"application/json","{\"ok\":true}");
}
void apiStreamStop() {
  streamActive = false;
  delay(150);   // let stream handler exit its loop
  webServer.send(200,"application/json","{\"ok\":true}");
}

void apiStreamQuality() {
  bool wasStreaming = streamActive;
  // Stop stream before changing resolution
  if (wasStreaming) {
    streamActive = false;
    delay(200);   // let httpd task finish current frame
  }
  if (webServer.hasArg("res")) {
    int r = webServer.arg("res").toInt();
    if (r >= 0 && r <= 13) { streamFrameSize = r; }
  }
  if (webServer.hasArg("fps")) {
    int f = webServer.arg("fps").toInt();
    if (f >= 1 && f <= 30) { streamFps = f; }
  }
  // Reinit camera at new resolution
  applyStreamResolution();
  delay(100);
  if (wasStreaming) { streamActive = true; }
  webServer.send(200,"application/json","{\"ok\":true}");
}

