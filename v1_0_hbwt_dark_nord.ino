bool initSD() {
  if (!SD_MMC.begin("/sdcard", true)) { Serial.println("💾 Failed"); return false; }
  if (SD_MMC.cardType() == CARD_NONE) { Serial.println("💾 No card"); return false; }
  Serial.printf("[SD] Ready %.1f GB\n",
    (float)SD_MMC.totalBytes() / (1024.0*1024*1024));
  return true;
}

